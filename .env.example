# =============================================================================
# SMG Transport Agency — Environment Variables (TEMPLATE)
# Copy this file to ".env.local" and fill in real values for each environment.
# NEVER commit ".env.local" or real secrets to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# RUNTIME MODE
# DEMO mode runs the whole app on an in-memory mock data layer with no external
# services required — ideal for local demos. Set to "false" to use real Firebase.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEMO_MODE=true

# -----------------------------------------------------------------------------
# FIREBASE — CLIENT (safe to expose; these are public identifiers, not secrets)
# Firebase console > Project settings > General > Your apps > Web app config
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1

# Set true after deploying the Firebase callable askChatbot function.
# When false, the chatbot uses the local Next.js backend fallback for demos/dev.
NEXT_PUBLIC_USE_FIREBASE_CHATBOT=false

# Optional Firebase App Check public reCAPTCHA Enterprise/Site key for client setup.
# Enforcement is controlled server-side for Cloud Functions.
NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=

# -----------------------------------------------------------------------------
# FIREBASE — ADMIN (SERVER ONLY — keep secret)
# Firebase console > Project settings > Service accounts > Generate new key
# For FIREBASE_PRIVATE_KEY keep the literal "\n" escapes on a single line.
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase/Google Cloud local admin scripts may alternatively use Application
# Default Credentials. Do not commit service-account JSON files.
GOOGLE_APPLICATION_CREDENTIALS=

# -----------------------------------------------------------------------------
# PAYSTACK (TEST MODE) — https://dashboard.paystack.com/#/settings/developers
# Use test keys (sk_test_..., pk_test_...) during development. Never use live
# keys locally. PAYSTACK_SECRET_KEY and WEBHOOK_SECRET are server-only.
# -----------------------------------------------------------------------------
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
# Active payment provider: "mock" (default for demo) | "paystack"
PAYMENT_PROVIDER=mock

# -----------------------------------------------------------------------------
# EMAIL (SMTP / Nodemailer) — used to send e-tickets and receipts
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# -----------------------------------------------------------------------------
# SMS PROVIDER (abstraction — supply credentials when a provider is chosen)
# e.g. SMS_PROVIDER=arkesel|hubtel|twilio
# -----------------------------------------------------------------------------
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=

# -----------------------------------------------------------------------------
# VERTEX AI / CHATBOT (SERVER ONLY)
# Vertex is called only from Firebase Cloud Functions or protected server code.
# Model can also be controlled through Firebase Remote Config.
# -----------------------------------------------------------------------------
VERTEX_AI_LOCATION=global
VERTEX_AI_DEFAULT_MODEL=gemini-3.5-flash
FUNCTIONS_REGION=us-central1
ENFORCE_APP_CHECK=false

# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side signing secrets. Use long random values in hosted environments.
ADMIN_SESSION_SECRET=
QR_VERIFY_SECRET=

# First super admin bootstrap target is fixed in scripts/set-super-admin.ts:
# francis@pwavwe.com

# Seat hold lifetime in seconds (how long a seat is reserved before payment).
SEAT_HOLD_TTL_SECONDS=600

# Local-only demo admin seed (used by the seed script in DEMO mode ONLY).
# Do NOT set a production administrator password here.
DEMO_ADMIN_EMAIL=projects@azlearner.me
DEMO_ADMIN_PASSWORD=Demo!Admin2026
